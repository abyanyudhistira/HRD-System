# ============================================
# LinkedIn Crawler Configuration
# ============================================

# LinkedIn Login (OAuth recommended - browser will open for manual login)
USE_OAUTH_LOGIN=true

# LinkedIn Credentials (GANTI DENGAN PUNYA ANDA KECUALI COOKIENYA SUDAH ADA!)
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# ============================================
# Supabase Configuration
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# ============================================
# LavinMQ Configuration (RabbitMQ)
# ============================================
RABBITMQ_HOST=leopard.lmq.cloudamqp.com
RABBITMQ_PORT=5672
RABBITMQ_USER=your_username
RABBITMQ_PASS=your_password
RABBITMQ_VHOST=your_username
RABBITMQ_QUEUE=linkedin_profiles
SCORING_QUEUE=scoring_queue

# ============================================
# Performance Optimization Pools
# ============================================
# Number of concurrent workers (default: 3)
NUM_WORKERS=3

# Browser pool size (default: 3)
BROWSER_POOL_SIZE=3

# Maximum browser age in minutes before refresh (default: 60)
MAX_BROWSER_AGE_MINUTES=60

# Database connection pool size (default: 5)
DB_POOL_SIZE=5

# Maximum connection age in minutes before refresh (default: 30)
MAX_CONNECTION_AGE_MINUTES=30

# ============================================
# Smart Queue Management
# ============================================
# Database check interval in seconds (default: 60 = 1 minute)
DB_CHECK_INTERVAL=60

# Scheduler polling interval in seconds (default: 60 = 1 minute)
POLL_INTERVAL=60

# Maximum number of workers (default: 3)
MAX_WORKERS=3

# Delay antar aksi (scroll, click, dll)
MIN_DELAY=0.5
MAX_DELAY=1

# Delay antar profile (anti-detection)
PROFILE_DELAY_MIN=3.0
PROFILE_DELAY_MAX=5.0

# Headless mode (false = show browser, true = hide browser)
HEADLESS=false
