# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Supabase Configuration (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# Frontend URL (for CORS)
# Local development
FRONTEND_URL=http://localhost:3000

# Production (Vercel) - uncomment when deploying
# FRONTEND_URL=https://your-app.vercel.app

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Scheduler Configuration
SCHEDULER_TIMEZONE=Asia/Jakarta

# RabbitMQ Configuration
# For local development (Docker)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=password123
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=linkedin_profiles
SCORING_QUEUE=scoring_queue
OUTREACH_QUEUE=outreach_queue

# For GCP production, use Cloud Pub/Sub or managed RabbitMQ
# RABBITMQ_HOST=your-gcp-rabbitmq-instance
# RABBITMQ_USER=your_production_user
# RABBITMQ_PASS=your_production_password

# Default Settings
DEFAULT_REQUIREMENTS_ID=desk_collection
