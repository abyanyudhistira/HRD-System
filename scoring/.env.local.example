# PostgreSQL Configuration (connect to Docker container from host)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hrd_system
POSTGRES_USER=hrd_user
POSTGRES_PASSWORD=hrd_password_change_me

# RabbitMQ Configuration (connect to Docker container from host)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/
SCORING_QUEUE=scoring_queue
