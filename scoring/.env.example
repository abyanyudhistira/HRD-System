# ============================================
# RabbitMQ Configuration
# ============================================
# For local development (Docker)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=password123
RABBITMQ_VHOST=/
SCORING_QUEUE=scoring_queue

# For GCP production
# RABBITMQ_HOST=your-gcp-rabbitmq-instance
# RABBITMQ_USER=your_production_user
# RABBITMQ_PASSWORD=your_production_password

# ============================================
# Supabase Configuration (Optional)
# ============================================
# Only needed if you want to save scores to Supabase
# Get from: https://supabase.com → Project Settings → API

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_here
